{
  "name": "@orale/functions",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "serve": "pnpm run build && firebase emulators:start --only functions,firestore",
    "deploy": "pnpm run build && firebase deploy --only functions"
  },
  "dependencies": {
    "@orale/shared": "workspace:*",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "firebase-functions-test": "^3.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.2"
  }
}
