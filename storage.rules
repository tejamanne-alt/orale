rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Vault media (photos, voice notes) lives at groups/{groupId}/vault/**
    // and is restricted to signed-in members of that group.
    match /groups/{groupId}/vault/{allPaths=**} {
      allow read, write: if request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/groups/$(groupId)).data.memberIds;
    }
  }
}
